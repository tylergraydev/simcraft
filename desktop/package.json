{
  "name": "simhammer-desktop",
  "version": "1.5.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "npm run build:frontend && npm run build:backend && electron-builder",
    "publish": "node scripts/publish.js",
    "build:frontend": "npm run --prefix ../frontend build:desktop && node scripts/copy-frontend.js",
    "build:backend": "node scripts/build-backend.js"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.simhammer.app",
    "productName": "SimHammer",
    "files": [
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "resources/data",
        "to": "data"
      },
      {
        "from": "resources/simc",
        "to": "simc"
      },
      {
        "from": "resources/frontend",
        "to": "frontend"
      },
      {
        "from": "resources/backend",
        "to": "backend"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.png"
    },
    "linux": {
      "target": ["AppImage", "deb"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "sortbek",
      "repo": "simcraft"
    }
  }
}
